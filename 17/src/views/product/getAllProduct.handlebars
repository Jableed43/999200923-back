<h2>{{title}}</h2>
{{#if (or (eq user.role 'administrador') (eq user.role 'vendedor'))}}
    <a href="/product/create" class="btn">Crear nuevo producto</a>
{{/if}}

{{#if products.length}}
    <table class="user-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Categoría</th>
                <th>Estado</th>
                <th>Stock</th>
                {{#if (or (eq user.role 'administrador') (eq user.role 'vendedor'))}}
                    <th>Acciones</th>
                {{/if}}
            </tr>
        </thead>
        <tbody>
            {{#each products}}
                <tr>
                    <td>
                        {{name}}
                        {{#if highlighted}}<span class="badge">Destacado</span>{{/if}}
                    </td>
                    <td>${{price}}</td>
                    <td>{{#if category}}{{category.name}}{{else}}Sin categoría{{/if}}</td>
                    <td>{{status}}</td>
                    <td>{{quantity}}</td>
                    
                    {{#if (or (eq ../user.role 'administrador') (eq ../user.role 'vendedor'))}}
                        <td class="actions">
                            <a href="/product/update/{{_id}}" class="btn-edit">Editar</a>
                            <form action="/product/{{_id}}?_method=delete" method="POST" class="inline-form">
                                <button type="submit" class="btn-delete" onclick="return confirm('¿Eliminar producto?')">Eliminar</button>
                            </form>
                        </td>
                    {{/if}}
                </tr>
            {{/each}}
        </tbody>
    </table>

{{else}}
    <p>No hay productos registrados.</p>
{{/if}}