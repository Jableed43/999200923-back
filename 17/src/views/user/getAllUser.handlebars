<h2>Lista de usuarios</h2>
<a href="/user/create">Crear usuario</a>
{{#if users.length}}
    <table>
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Email</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each users}}
                <tr>
                    <td>{{name}}</td>
                    <td>{{lastName}}</td>
                    <td>{{email}}</td>
                    <td style="display: flex;
    gap: 10px;
    align-items: center;"> <form action="/user/{{_id}}?_method=delete" method="post" >
                            <button type="submit" onclick="return confirm('¿Estas seguro que quieres eliminar el usuario?')" >Eliminar</button>
                        </form> 
                        
                        <a href="/user/update/{{_id}}" style="padding: 1px 6px; color: black; background-color: rgb(238, 238, 238); border: gray solid 1px; text-decoration: none; border-radius: 3px; font-size: 13.33; font-family:Arial, Helvetica, sans-serif; font-weight:lighter " >Editar</a>
                         </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
{{else}}
    <p>No hay usuarios registrados.</p>
{{/if}}